<section class="about" id="about">
  <div class="reveal-left">
    <div class="about-img-wrap">
      <div class="about-img-placeholder">
        <img decoding="async" loading="lazy" class="about-bg-img" src="data:image/jpeg;base64," alt="Studio Background">
        <div class="about-bg-overlay"></div>
        <div class="about-dp-wrap">
          <img decoding="async" class="about-dp" src="data:image/png;base64," alt="Surya">
        </div>
        <div class="about-frame"></div>
      </div>
      <div class="about-years">
        <span class="about-years-num">5+</span>
        <span class="about-years-label">Years of Vision</span>
      </div>
    </div>
  </div>

  <div class="reveal">
    <div class="section-label">About Me</div>
    <h2 class="section-title">THE ARTIST<br>BEHIND THE <em>LENS</em></h2>
    <p class="about-bio">
      I'm <strong>Surya</strong> — a cinematic video editor and cinematographer from <em>Bhubaneswar, Odisha</em>, with over <strong>5 years of experience</strong> crafting stories that evoke emotion, challenge perspective, and move audiences.
    </p>
    <p class="about-bio" style="margin-top:-.5rem">
      My work spans <em>music videos, brand campaigns, short films, and documentaries</em> — always rooted in intentional storytelling and cinematic visual language. From raw emotion to refined aesthetics, I focus on creating films that feel <strong>immersive, authentic, and emotionally driven.</strong>
    </p>
    <p class="about-bio" style="margin-top:-.5rem">
      Now based in <em>Bhubaneswar, Odisha</em> and working with clients globally — I approach every project with the belief that <strong>every frame is a decision, and every cut, a heartbeat.</strong>
    </p>
    <div class="about-skills">
      <span class="skill-tag">Adobe Premiere Pro</span>
      <span class="skill-tag">DaVinci Resolve</span>
      <span class="skill-tag">After Effects</span>
      <span class="skill-tag">Final Cut Pro</span>
      <span class="skill-tag">Cinema 4D</span>
      <span class="skill-tag">Color Grading</span>
      <span class="skill-tag">Sound Design</span>
      <span class="skill-tag">VFX / Compositing</span>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
  <img class="services-bg" loading="lazy" decoding="async" src="data:image/avif;base64," alt="">
  <div class="services-overlay"></div>
  <div class="reveal" style="text-align:center;max-width:600px;margin:0 auto 0">
    <div class="section-label" style="justify-content:center">What I Do</div>
    <h2 class="section-title">MY <em>SERVICES</em></h2>
  </div>

  <div class="services-grid reveal">
    <div class="service-item">
      <span class="service-num">01</span>
      <span class="service-icon">🎬</span>
      <div class="service-name">Video Editing</div>
      <p class="service-desc">Precision cutting, pacing, and narrative flow. From raw footage to cinematic masterpiece — I sculpt stories that hold attention from first frame to last.</p>
      <div class="service-tags">
        <span class="service-tag">Premiere Pro</span>
        <span class="service-tag">Final Cut</span>
        <span class="service-tag">Resolve</span>
      </div>
    </div>
    <div class="service-item">
      <span class="service-num">02</span>
      <span class="service-icon">🎨</span>
      <div class="service-name">Color Grading</div>
      <p class="service-desc">Mood through color. I develop signature LUTs and grade your footage to create a distinct, emotive visual identity that becomes instantly recognizable.</p>
      <div class="service-tags">
        <span class="service-tag">DaVinci Resolve</span>
        <span class="service-tag">LUT Design</span>
      </div>
    </div>
    <div class="service-item">
      <span class="service-num">03</span>
      <span class="service-icon">📽️</span>
      <div class="service-name">Cinematography</div>
      <p class="service-desc">On-set direction and camera work. I capture footage with editorial intent — knowing exactly how every shot will cut together before we even hit record.</p>
      <div class="service-tags">
        <span class="service-tag">Camera Op</span>
        <span class="service-tag">Lighting</span>
        <span class="service-tag">Direction</span>
      </div>
    </div>
    <div class="service-item">
      <span class="service-num">04</span>
      <span class="service-icon">✨</span>
      <div class="service-name">Motion Graphics</div>
      <p class="service-desc">Titles, transitions, and visual effects that feel native to the footage — never bolted on. Motion design that serves the story, not the other way around.</p>
      <div class="service-tags">
        <span class="service-tag">After Effects</span>
        <span class="service-tag">Cinema 4D</span>
        <span class="service-tag">VFX</span>
      </div>
    </div>
    <div class="service-item wide">
      <span class="service-num">05</span>
      <span class="service-icon">📸</span>
      <div class="service-name">Photography</div>
      <p class="service-desc">Still frames that speak volumes. From editorial portraits and product shoots to event coverage and cinematic stills — I bring the same obsessive attention to composition, lighting, and mood to every photograph. Each image is a story frozen in time, crafted to complement and elevate your visual brand.</p>
      <div class="service-tags">
        <span class="service-tag">Portrait</span>
        <span class="service-tag">Editorial</span>
        <span class="service-tag">Product Shoot</span>
        <span class="service-tag">Event Coverage</span>
        <span class="service-tag">Lightroom</span>
        <span class="service-tag">Photoshop</span>
      </div>
    </div>
  </div>
</section>

