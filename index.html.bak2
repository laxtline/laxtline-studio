<!-- ===== SECTION ENTRANCE FX (self-contained, GPU-only, reduced-motion safe) ===== -->
<style id="fx-section-anim">
  .fx-label{opacity:0;transform:translateX(-22px);transition:opacity .7s cubic-bezier(.22,.61,.36,1),transform .7s cubic-bezier(.22,.61,.36,1);will-change:opacity,transform}
  .fx-label::before{transform:scaleX(0);transform-origin:left center;transition:transform .7s cubic-bezier(.22,.61,.36,1) .12s}
  .fx-label.fx-in{opacity:1;transform:translateX(0)}
  .fx-label.fx-in::before{transform:scaleX(1)}
  .fx-title{opacity:0;transform:translateY(34px);filter:blur(6px);transition:opacity .8s cubic-bezier(.22,.61,.36,1) .12s,transform .8s cubic-bezier(.22,.61,.36,1) .12s,filter .8s ease .12s;will-change:opacity,transform,filter}
  .fx-title.fx-in{opacity:1;transform:translateY(0);filter:blur(0)}
  .fx-title em{transition:text-shadow .9s ease .35s}
  .fx-title.fx-in em{text-shadow:0 0 22px rgba(232,57,42,.45)}
  .fx-logo-init{opacity:0;transform:translateY(-12px)}
  .fx-logo-in{opacity:1;transform:translateY(0);transition:opacity .8s ease,transform .8s cubic-bezier(.22,.61,.36,1)}
  /* ── Per-section entrance for content (re-plays every time the section enters view) ── */
  .fxe{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.22,.61,.36,1),transform .7s cubic-bezier(.22,.61,.36,1);will-change:opacity,transform}
  .fxe-in{opacity:1;transform:none}
  @media (prefers-reduced-motion:reduce){
    .fx-label,.fx-label::before,.fx-title,.fx-logo-init{opacity:1!important;transform:none!important;filter:none!important;transition:none!important}
    .fxe{opacity:1!important;transform:none!important;transition:none!important}
  }
</style>
<script id="fx-section-anim-js">
(function(){
  function init(){
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion:reduce)').matches;
    // Logo entrance on load
    var logo = document.querySelector('.nav-logo');
    if(logo && !prefersReduced){
      logo.classList.add('fx-logo-init');
      requestAnimationFrame(function(){ requestAnimationFrame(function(){ logo.classList.add('fx-logo-in'); }); });
      setTimeout(function(){ logo.classList.add('fx-logo-in'); }, 1200);
    }
    var heads = document.querySelectorAll('.section-label,.section-title');
    if(!heads.length) return;
    if(prefersReduced){ return; } // CSS leaves them fully visible
    heads.forEach(function(el){ el.classList.add(el.classList.contains('section-label')?'fx-label':'fx-title'); });
    if(!('IntersectionObserver' in window)){
      heads.forEach(function(el){ el.classList.add('fx-in'); });
      return;
    }
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('fx-in'); obs.unobserve(e.target); } });
    },{threshold:.15,rootMargin:'0px 0px -60px 0px'});
    heads.forEach(function(el){ obs.observe(el); });
    // Safety: force-show anything still hidden after 2.5s
    setTimeout(function(){
      document.querySelectorAll('.fx-label:not(.fx-in),.fx-title:not(.fx-in)').forEach(function(el){ el.classList.add('fx-in'); });
    }, 2500);
  }
  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', init); }
  else { init(); }
})();
</script>

<!-- ===== PER-SECTION CONTENT ENTRANCE (replays on every scroll-in) ===== -->
<script id="fxe-section-anim-js">
(function(){
  function init(){
    if(window.matchMedia && window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
    // Sections to animate — everything EXCEPT the project gallery (#work) and all projects (#all-work)
    var SECTIONS = ['#home','#about','#services','#software','#contact','#socials'];
    var groups = [];
    SECTIONS.forEach(function(sel){
      var sec = document.querySelector(sel);
      if(!sec) return;
      // Pick the content elements inside this section to animate (skip the section-title/label that the fx- system already handles)
      var sel2 = '.hero-tag,.hero-title,.hero-sub,.hero-meta,.about-bio,.about-skills,.about-img-wrap,.about-years,.service-item,.sw-category,.contact-info-item,.contact-socials,.whatsapp-btn,.social-btn,.socials-header p,.about-dp-wrap,p';
      var els = Array.prototype.slice.call(sec.querySelectorAll(sel2));
      // De-duplicate (a node matched by two selectors) and keep order
      els = els.filter(function(el,i){ return els.indexOf(el)===i; });
      if(!els.length) return;
      els.forEach(function(el){ el.classList.add('fxe'); });
      groups.push({sec:sec, els:els});
    });
    if(!groups.length) return;

    function play(g){
      g.els.forEach(function(el,i){
        el.style.transitionDelay = Math.min(i*0.06, 0.5)+'s';
        el.classList.add('fxe-in');
      });
    }
    function reset(g){
      g.els.forEach(function(el){
        el.style.transitionDelay = '';
        el.classList.remove('fxe-in');
      });
    }

    if(!('IntersectionObserver' in window)){
      groups.forEach(function(g){ g.els.forEach(function(el){ el.classList.add('fxe-in'); }); });
      return;
    }
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        var g = groups.filter(function(x){ return x.sec===e.target; })[0];
        if(!g) return;
        if(e.isIntersecting){ play(g); }
        else { reset(g); } // reset when fully out of view so it replays on next entry
      });
    },{threshold:.12});
    groups.forEach(function(g){ obs.observe(g.sec); });

    // Safety: force-show after 3s anything stuck hidden while in viewport
    setTimeout(function(){
      groups.forEach(function(g){
        var r = g.sec.getBoundingClientRect();
        if(r.top < window.innerHeight && r.bottom > 0){ play(g); }
      });
    }, 3000);
  }
  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', init); }
  else { init(); }
})();
</script>
</head>
